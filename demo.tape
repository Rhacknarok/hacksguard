Output assets/hacksguard.gif

Set Shell "zsh"
Set PlaybackSpeed 0.25
Set FontSize 16
Set Width 1920
Set Height 1080

# Lancer Hacksguard sur un fichier cible (à adapter)
Type "/tmp/hacksguard /tmp/sf.exe"
Sleep 500ms
Enter

Sleep 5s

# Défilement automatique (flèches droites, 4s par onglet)
Right
Sleep 4s
Right
Sleep 4s
Right
Sleep 4s
Right
Sleep 4s
Right
Sleep 4s
Right
Sleep 4s
Right
Sleep 4s
Right
Sleep 4s

# Quitter
Type "q"
Sleep 2s
